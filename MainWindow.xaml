<Window x:Class="App_Desk3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App_Desk3"
        mc:Ignorable="d"
        Title="Menu de pizzas" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label x:Name="pizza_sabor" Content="INDIQUE SU SABOR DE PIZZA &#xD;&#xA;FAVORITO" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="68" Margin="7,10,0,0" VerticalAlignment="Top" Width="310" FontSize="20" FontWeight="Bold" FontFamily="Arial" Background="#FFE67C23" Foreground="White" BorderBrush="#FF2AE1F9"/>
        <CheckBox x:Name="ck_01" Content="Pizza de queso 350$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="15,97,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Calibri" FontStyle="Italic" FontWeight="Bold"/>
        <CheckBox x:Name="ck_02" Content="Pizza de jamon 450$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="15,137,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Calibri" FontWeight="Bold" FontStyle="Italic"/>
        <CheckBox x:Name="ck_03" Content="Pizza de jamon y queso 500$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="15,175,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Calibri" FontStyle="Italic" FontWeight="Bold"/>
        <CheckBox x:Name="ck_04" Content="Pizza de pepperoni 650$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="15,211,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Calibri" FontStyle="Italic" FontWeight="Bold"/>
        <CheckBox x:Name="ck_05" Content="Pizza de vegetales 700$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="15,249,0,0" VerticalAlignment="Top" FontSize="24" FontFamily="Calibri" FontStyle="Italic" FontWeight="Bold"/>
        <RadioButton x:Name="rb_01" Content="Coca Cola 100$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="427,97,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <Label x:Name="bebida_sabor" Content="INDIQUE SU SABOR DE BEBIDA &#xD;&#xA;FAVORITO" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="68" Margin="427,8,0,0" VerticalAlignment="Top" Width="329" FontSize="20" FontWeight="Bold" FontFamily="Arial" Background="#FFE67C23" Foreground="White" BorderBrush="#FF2AE1F9"/>
        <RadioButton x:Name="rb_02" Content="Pepsi 75$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="427,164,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <RadioButton x:Name="rb_03" Content="Kola Real 40$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="427,200,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <RadioButton x:Name="rb_04" Content="Country Club 35$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="427,234,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <RadioButton x:Name="rb_05" Content="Red Rock 80$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="427,131,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <RadioButton x:Name="rb_06" Content="7up 60$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="631,97,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <RadioButton x:Name="rb_07" Content="Sprite 75$" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="631,130,0,0" VerticalAlignment="Top" FontFamily="Calibri" FontSize="24" FontWeight="Bold" FontStyle="Italic"/>
        <Button x:Name="b_ordenar" Content="ORDENAR" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="49" Margin="15,308,0,0" VerticalAlignment="Top" Width="105" Background="#FFEC571F" Foreground="#FFFFFBFB" FontFamily="Calibri" FontWeight="Bold" FontSize="20" Click="b_ordenar_Click"/>
        <Button x:Name="b_cancelar" Content="CANCELAR" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="49" Margin="128,308,0,0" VerticalAlignment="Top" Width="105" Background="#FFEC571F" Foreground="#FFFFFBFB" FontFamily="Calibri" FontWeight="Bold" FontSize="20" Click="b_cancelar_Click"/>
        <Label x:Name="l_orden" Content="TOTAL DE LA ORDEN:" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="38" Margin="341,308,0,0" VerticalAlignment="Top" Width="204" FontFamily="Calibri" FontWeight="Bold" FontSize="22" Background="#FFF1ECEC"/>
        <Label x:Name="l_precio" Content="0.00$RD" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="46" Margin="341,364,0,0" VerticalAlignment="Top" Width="440" FontFamily="Calibri" FontWeight="Bold" FontSize="22" Background="#FFF34D0E" Foreground="#FFF5EEEE"/>
        <Button x:Name="b_volver_ordenar" Content="VOLVER A ORDENAR" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="49" Margin="15,370,0,0" VerticalAlignment="Top" Width="289" Background="#FFEC571F" Foreground="#FFFFFBFB" FontFamily="Calibri" FontWeight="Bold" FontSize="20" Click="b_volver_ordenar_Click"/>
        <Button x:Name="b_volver_ordenar_Copy" Content="CLEAR MESSAGE" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="38" Margin="554,308,0,0" VerticalAlignment="Top" Width="227" Background="#FFF51414" Foreground="#FFFFFBFB" FontFamily="Calibri" FontWeight="Bold" FontSize="20" Click="b_clear_Click"/>
        <Button x:Name="b_exit" Content="EXIT" Grid.ColumnSpan="2" HorizontalAlignment="Left" Height="49" Margin="242,308,0,0" VerticalAlignment="Top" Width="62" Background="#FFF50000" Foreground="#FFFFFBFB" FontFamily="Calibri" FontWeight="Bold" FontSize="20" Click="b_exit_Click"/>

    </Grid>
</Window>
